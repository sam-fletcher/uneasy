# save-exact=true: when you run `npm install <package>`, save the exact
# version (e.g. "1.14.0") rather than a caret range ("^1.14.0").
#
# Caret ranges allow any compatible minor/patch update on the next `npm install`
# from scratch, which means a compromised patch release (as happened with axios
# in March 2026) can silently enter the project. Exact pins prevent this.
#
# Workflow note: package-lock.json is the real version lock for `npm ci`.
# This setting governs what gets written to package.json when you ADD a new
# package, keeping package.json and the lockfile consistent with each other.
save-exact=true
